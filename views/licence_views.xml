<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_licence_form" model="ir.ui.view">
        <field name="name">it.licence.form</field>
        <field name="model">it.licence</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="version"/>
                        <field name="licence_type"/>
                        <field name="state" readonly="1"/>
                        <field name="licence_key" password="True"/>
                    </group>
                    <group>
                        <field name="equipment_id"/>
                        <field name="employee_id"/>
                        <field name="contrat_id"/>
                        <field name="date_expiry"/>
                        <field name="days_remaining" readonly="1"
                            decoration-danger="days_remaining &lt; 0"
                            decoration-warning="days_remaining &lt; 30 and days_remaining &gt;= 0"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_it_licence_tree" model="ir.ui.view">
        <field name="name">it.licence.tree</field>
        <field name="model">it.licence</field>
        <field name="arch" type="xml">
            <list decoration-danger="days_remaining &lt; 0" decoration-warning="days_remaining &lt; 30 and days_remaining &gt;= 0">
                <field name="name"/>
                <field name="version"/>
                <field name="equipment_id"/>
                <field name="employee_id"/>
                <field name="date_expiry"/>
                <field name="days_remaining"/>
                <field name="state" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="view_it_licence_search" model="ir.ui.view">
        <field name="name">it.licence.search</field>
        <field name="model">it.licence</field>
        <field name="arch" type="xml">
            <search>
                <filter name="state_active" string="Active" domain="[('state','=','active')]"/>
                <filter name="state_expired" string="Expirée" domain="[('state','=','expired')]"/>
                <filter name="state_revoked" string="Révoquée" domain="[('state','=','revoked')]"/>
                <separator/>
                <filter name="type_perpetual" string="Perpétuelle" domain="[('licence_type','=','perpetual')]"/>
                <filter name="type_subscription" string="Abonnement" domain="[('licence_type','=','subscription')]"/>
                <filter name="type_trial" string="Essai" domain="[('licence_type','=','trial')]"/>
                <separator/>
                <field name="equipment_id"/>
                <field name="employee_id"/>
            </search>
        </field>
    </record>

    <record id="action_it_licence" model="ir.actions.act_window">
        <field name="name">Licences logicielles</field>
        <field name="res_model">it.licence</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_it_licence_search"/>
    </record>
</odoo>
