<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_intervention_form" model="ir.ui.view">
        <field name="name">it.intervention.form</field>
        <field name="model">it.intervention</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_clickable="1"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="equipment_id"/>
                        <field name="type"/>
                        <field name="technician_id"/>
                        <field name="state" readonly="1"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="duration_hours" readonly="1"/>
                        <field name="cost"/>
                        <field name="report"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_it_intervention_tree" model="ir.ui.view">
        <field name="name">it.intervention.tree</field>
        <field name="model">it.intervention</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="equipment_id"/>
                <field name="type"/>
                <field name="technician_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="duration_hours"/>
                <field name="cost"/>
                <field name="state" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="view_it_intervention_calendar" model="ir.ui.view">
        <field name="name">it.intervention.calendar</field>
        <field name="model">it.intervention</field>
        <field name="arch" type="xml">
            <calendar date_start="date_start" date_stop="date_end" color="type" string="Interventions">
                <field name="name"/>
                <field name="equipment_id"/>
            </calendar>
        </field>
    </record>

    <record id="view_it_intervention_search" model="ir.ui.view">
        <field name="name">it.intervention.search</field>
        <field name="model">it.intervention</field>
        <field name="arch" type="xml">
            <search>
                <filter name="type_corrective" string="Corrective" domain="[('type','=','corrective')]"/>
                <filter name="type_preventive" string="Préventive" domain="[('type','=','preventive')]"/>
                <separator/>
                <filter name="state_planned" string="Planifiée" domain="[('state','=','planned')]"/>
                <filter name="state_done" string="Terminée" domain="[('state','=','done')]"/>
                <field name="technician_id"/>
            </search>
        </field>
    </record>

    <record id="action_it_intervention" model="ir.actions.act_window">
        <field name="name">Interventions</field>
        <field name="res_model">it.intervention</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="search_view_id" ref="view_it_intervention_search"/>
    </record>
</odoo>
