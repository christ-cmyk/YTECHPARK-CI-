<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- it.equipment.category -->
    <record id="view_it_equipment_category_tree" model="ir.ui.view">
        <field name="name">it.equipment.category.tree</field>
        <field name="model">it.equipment.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_it_equipment_category_form" model="ir.ui.view">
        <field name="name">it.equipment.category.form</field>
        <field name="model">it.equipment.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_it_equipment_category" model="ir.actions.act_window">
        <field name="name">Catégories</field>
        <field name="res_model">it.equipment.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- it.equipment -->
    <record id="view_it_equipment_form" model="ir.ui.view">
        <field name="name">it.equipment.form</field>
        <field name="model">it.equipment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,assigned,maintenance,retired"/>
                    <button name="action_assign" type="object" string="Affecter" invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_maintenance" type="object" string="Mettre en maintenance" invisible="state != 'assigned'" class="btn-warning"/>
                    <button name="action_return_assigned" type="object" string="Retour affecté" invisible="state != 'maintenance'" class="btn-success"/>
                    <button name="action_open_reaffectation_wizard" type="object" string="Réaffecter" invisible="state != 'assigned'" class="btn-primary"/>
                    <button name="action_retire" type="object" string="Retirer" invisible="state not in ('draft', 'assigned', 'maintenance')" class="btn-danger"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <group>
                        <field name="name"/>
                        <field name="category_id"/>
                        <field name="serial_number"/>
                        <field name="location"/>
                        <field name="employee_id" readonly="state not in ('draft', False)"/>
                        <field name="department_id" readonly="state not in ('draft', False)"/>
                    </group>
                    <notebook>
                        <page string="Financier &amp; Garantie">
                            <group>
                                <field name="purchase_date"/>
                                <field name="warranty_date"/>
                                <field name="purchase_value"/>
                            </group>
                        </page>
                        <page string="Affectations">
                            <field name="affectation_ids">
                                <list>
                                    <field name="employee_id"/>
                                    <field name="department_id"/>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                    <field name="reason"/>
                                </list>
                            </field>
                        </page>
                        <page string="Interventions">
                            <field name="intervention_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="type"/>
                                    <field name="technician_id"/>
                                    <field name="date_start"/>
                                    <field name="duration_hours"/>
                                    <field name="cost"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Licences installées">
                            <field name="licence_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="version"/>
                                    <field name="employee_id"/>
                                    <field name="date_expiry"/>
                                    <field name="days_remaining"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_it_equipment_tree" model="ir.ui.view">
        <field name="name">it.equipment.tree</field>
        <field name="model">it.equipment</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'maintenance'" decoration-muted="state == 'retired'">
                <field name="name"/>
                <field name="category_id"/>
                <field name="serial_number"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="warranty_date"/>
                <field name="state" decoration-danger="state == 'maintenance'" decoration-muted="state == 'retired'"/>
            </list>
        </field>
    </record>

    <record id="view_it_equipment_kanban" model="ir.ui.view">
        <field name="name">it.equipment.kanban</field>
        <field name="model">it.equipment</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="category_id"/>
                <field name="employee_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_card_header">
                                <field name="name"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong>Catégorie :</strong>
                                <field name="category_id"/>
                                <br/>
                                <strong>Employé :</strong>
                                <field name="employee_id"/>
                                <br/>
                                <field name="state" widget="badge" decoration-danger="state == 'maintenance'" decoration-muted="state == 'retired'" decoration-success="state == 'assigned'" decoration-info="state == 'draft'"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_it_equipment_search" model="ir.ui.view">
        <field name="name">it.equipment.search</field>
        <field name="model">it.equipment</field>
        <field name="arch" type="xml">
            <search>
                <filter name="state_draft" string="Brouillon" domain="[('state','=','draft')]"/>
                <filter name="state_assigned" string="Affecté" domain="[('state','=','assigned')]"/>
                <filter name="state_maintenance" string="En maintenance" domain="[('state','=','maintenance')]"/>
                <filter name="state_retired" string="Retiré" domain="[('state','=','retired')]"/>
                <separator/>
                <filter name="group_category" string="Catégorie" context="{'group_by':'category_id'}"/>
                <filter name="group_department" string="Département" context="{'group_by':'department_id'}"/>
                <filter name="group_state" string="État" context="{'group_by':'state'}"/>
                <field name="category_id"/>
                <field name="department_id"/>
            </search>
        </field>
    </record>

    <record id="action_it_equipment" model="ir.actions.act_window">
        <field name="name">Équipements</field>
        <field name="res_model">it.equipment</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_it_equipment_search"/>
    </record>
</odoo>
