<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_it_parc" model="ir.module.category">
        <field name="name">IT Parc</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_it_technicien" model="res.groups">
        <field name="name">IT Technicien</field>
        <field name="category_id" ref="module_category_it_parc"/>
        <field name="comment">Lecture de tous les équipements, création et modification des interventions uniquement.</field>
    </record>

    <record id="group_it_manager" model="res.groups">
        <field name="name">IT Manager</field>
        <field name="category_id" ref="module_category_it_parc"/>
        <field name="implied_ids" eval="[(4, ref('group_it_technicien'))]"/>
        <field name="comment">Accès complet à tous les modèles et fonctionnalités du module.</field>
    </record>

</odoo>
