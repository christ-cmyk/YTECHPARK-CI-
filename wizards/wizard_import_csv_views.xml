<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_wizard_import_csv_form" model="ir.ui.view">
        <field name="name">it.wizard.import.csv.form</field>
        <field name="model">it.wizard.import.csv</field>
        <field name="arch" type="xml">
            <form string="Import CSV équipements">
                <group>
                    <field name="csv_file" filename="csv_filename"/>
                    <field name="csv_filename" invisible="1"/>
                </group>
                <group>
                    <field name="result_message" invisible="not result_message"/>
                </group>
                <group string="Colonnes attendues">
                    <p>name, serial_number, category, location, employee_login, purchase_date (YYYY-MM-DD), warranty_date (YYYY-MM-DD), purchase_value</p>
                </group>
                <footer>
                    <button name="action_import" type="object" string="Importer" class="btn-primary"/>
                    <button string="Fermer" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_it_wizard_import_csv" model="ir.actions.act_window">
        <field name="name">Importer via CSV</field>
        <field name="res_model">it.wizard.import.csv</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
