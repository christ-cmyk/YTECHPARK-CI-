<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_wizard_reaffectation_form" model="ir.ui.view">
        <field name="name">it.wizard.reaffectation.form</field>
        <field name="model">it.wizard.reaffectation</field>
        <field name="arch" type="xml">
            <form string="Réaffecter l'équipement">
                <group>
                    <field name="equipment_id"/>
                    <field name="employee_id" domain="[('active', '=', True)]"/>
                    <field name="department_id"/>
                    <field name="reason"/>
                    <field name="date_start"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirmer la réaffectation" class="btn-primary"/>
                    <button string="Annuler" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_it_wizard_reaffectation" model="ir.actions.act_window">
        <field name="name">Réaffecter l'équipement</field>
        <field name="res_model">it.wizard.reaffectation</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
