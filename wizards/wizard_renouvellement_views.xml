<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_wizard_renouvellement_form" model="ir.ui.view">
        <field name="name">it.wizard.renouvellement.form</field>
        <field name="model">it.wizard.renouvellement</field>
        <field name="arch" type="xml">
            <form string="Renouveler le contrat">
                <group>
                    <field name="contrat_id"/>
                    <field name="new_date_start"/>
                    <field name="new_date_end"/>
                    <field name="new_amount"/>
                    <field name="notes"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Renouveler" class="btn-primary"/>
                    <button string="Annuler" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_it_wizard_renouvellement" model="ir.actions.act_window">
        <field name="name">Renouveler le contrat</field>
        <field name="res_model">it.wizard.renouvellement</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
