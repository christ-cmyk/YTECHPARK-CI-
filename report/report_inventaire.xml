<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_inventaire" model="ir.actions.report">
        <field name="name">Inventaire du parc informatique</field>
        <field name="model">it.equipment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_inventaire_template</field>
        <field name="report_file">it_parc.report_inventaire_template</field>
        <field name="binding_model_id" ref="model_it_equipment"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_inventaire_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2 style="color:#1A3A5C; border-bottom:2px solid #1A3A5C; padding-bottom:8px;">
                        Inventaire du Parc Informatique
                    </h2>
                    <p class="text-muted">
                        Généré le : <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y à %H:%M')"/>
                        — Total : <strong><t t-esc="len(docs)"/> équipement(s)</strong>
                    </p>

                    <table class="table table-sm table-bordered table-striped" style="font-size:11px;">
                        <thead style="background:#1A3A5C; color:white;">
                            <tr>
                                <th>#</th>
                                <th>Nom</th>
                                <th>Catégorie</th>
                                <th>N° Série</th>
                                <th>Employé</th>
                                <th>Département</th>
                                <th>Site</th>
                                <th>Fin garantie</th>
                                <th>Valeur (FCFA)</th>
                                <th>État</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="docs" t-as="o">
                                <td><t t-esc="o_index + 1"/></td>
                                <td><span t-field="o.name"/></td>
                                <td><span t-field="o.category_id"/></td>
                                <td><span t-field="o.serial_number"/></td>
                                <td><span t-field="o.employee_id"/></td>
                                <td><span t-field="o.department_id"/></td>
                                <td><span t-field="o.location"/></td>
                                <td><span t-field="o.warranty_date"/></td>
                                <td><span t-field="o.purchase_value"/></td>
                                <td>
                                    <span t-esc="dict(o.fields_get(['state'])['state']['selection'])[o.state]"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <h4 style="color:#185FA5; margin-top:24px;">Résumé par état</h4>
                    <table class="table table-sm table-bordered" style="width:40%;">
                        <thead style="background:#1A3A5C; color:white;">
                            <tr><th>État</th><th>Nombre</th></tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Brouillon</td>
                                <td><t t-esc="len(docs.filtered(lambda e: e.state == 'draft'))"/></td>
                            </tr>
                            <tr>
                                <td>Affecté</td>
                                <td><t t-esc="len(docs.filtered(lambda e: e.state == 'assigned'))"/></td>
                            </tr>
                            <tr>
                                <td>En maintenance</td>
                                <td><t t-esc="len(docs.filtered(lambda e: e.state == 'maintenance'))"/></td>
                            </tr>
                            <tr>
                                <td>Retiré</td>
                                <td><t t-esc="len(docs.filtered(lambda e: e.state == 'retired'))"/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
